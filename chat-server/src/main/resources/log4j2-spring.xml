<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Properties>
        <Property name="LOG_DIR">./logs</Property>
        <Property name="PATTERN">%d{yyyy-MM-dd HH:mm:ss,SSS} [%t] %c{1} [%M] %-5p %msg%n%throwable</Property>
        <Property name="MAX_SIZE">1GB</Property>
        <Property name="PACKET_MAX_SIZE">128MB</Property>
        <Property name="KEEP_DAYS">7d</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${PATTERN}"/>
        </Console>

        <RollingRandomAccessFile name="ServerFile"
                                 fileName="${LOG_DIR}/chat-server.log"
                                 filePattern="${LOG_DIR}/chat-server-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${PATTERN}"/>

            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="${MAX_SIZE}"/>
            </Policies>

            <DefaultRolloverStrategy fileIndex="min" max="5">
                <Delete basePath="${LOG_DIR}" maxDepth="1">
                    <IfFileName glob="chat-server-*.log"/>
                    <IfLastModified age="${KEEP_DAYS}"/>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingRandomAccessFile>

        <RollingRandomAccessFile name="PacketsFile"
                                 fileName="${LOG_DIR}/packets.log"
                                 filePattern="${LOG_DIR}/packets-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${PATTERN}"/>

            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="${PACKET_MAX_SIZE}"/>
            </Policies>

            <DefaultRolloverStrategy fileIndex="min" max="5">
                <Delete basePath="${LOG_DIR}" maxDepth="1">
                    <IfFileName glob="packets-*.log"/>
                    <IfLastModified age="${KEEP_DAYS}"/>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingRandomAccessFile>
    </Appenders>

    <Loggers>

        <!-- LOG everything at TRACE level -->
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ServerFile"/>
        </Root>

        <Logger name="com.jftse.emulator" level="trace"/>

        <Logger name="PacketLogger" level="trace" additivity="false">
            <AppenderRef ref="PacketsFile"/>
        </Logger>
        <Logger name="ScriptLogger" level="trace" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ServerFile"/>
        </Logger>
        <Logger name="TimeSyncLogger" level="trace" additivity="false">
            <AppenderRef ref="ServerFile"/>
        </Logger>
    </Loggers>

</Configuration>
