message CMSG_PlayerUseSkill (0x18E9) {
    byte attackerPosition = 1;
    byte targetPosition = 2;
    bool isQuickSlot = 3;
    byte quickSlotIndex = 4;
    byte skillIndex = 5;
    int32 sourceValue = 6; // quickslot: item count, not quickslot: crystalId
    int32 playerPocketId = 7;
    byte seed = 8;
    float xTarget = 9;
    float zTarget = 10;
    float yTarget = 11;
}
